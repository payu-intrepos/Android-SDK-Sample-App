<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:minWidth="300dp"
    android:orientation="vertical"
    android:padding="10dp">

    <TextView
        android:id="@+id/txt"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="10dp"
        android:gravity="center_horizontal"
        android:text="Enter Details"
        android:textColor="@android:color/black"
        android:textSize="18sp" />

    <EditText
        android:id="@+id/payu_access_key"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="E5ABOXOWAAZNXB6JEF5Z"
        android:textSize="15sp" />

    <EditText
        android:id="@+id/payu_cardbin"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="CardBin e.g. 434668"
        android:text=""
        android:textSize="15sp" />

    <EditText
        android:id="@+id/payu_amount"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Amount e.g. 100"
        android:text=""
        android:textSize="15sp" />
    <EditText
        android:id="@+id/payu_currency"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="INR"
        android:textSize="15sp" />
    <EditText
        android:id="@+id/payu_secret"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="e425e539233044146a2d185a346978794afd7c66"
        android:textSize="15sp" />
    <EditText
        android:id="@+id/payu_order_id"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Order id.e.g"
        android:textSize="15sp" />

    <Button
        android:id="@+id/btn_submit"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Submit" />
</LinearLayout>